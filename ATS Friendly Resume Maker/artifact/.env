# Gemini API key — required for auto-parsing uploaded resumes.
# Get one (free tier available) at https://aistudio.google.com/apikey
GEMINI_API_KEY=<gemini api key>

# Optional: override the model. Default is gemini-2.5-flash (fast & cheap).
# Other options: gemini-2.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash
